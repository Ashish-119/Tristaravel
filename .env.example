# ─────────────────────────────────────────────────────────────────────────────
# Tristaravel web app — environment variables
#
# Copy this file to `.env` for local dev, or set these in your host's dashboard
# (e.g. Railway → service → Variables) for production. NEVER commit a real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string (where quotes + drivers are stored).
# Local dev (docker-compose):  postgres://postgres:postgres@localhost:5432/anything
# Railway:                     use the value Railway's Postgres plugin provides
#                              (Variables → Postgres → DATABASE_URL → Reference).
# Neon / other cloud Postgres: append ?sslmode=require to the URL.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/anything

# Google Maps API key with the "Distance Matrix API" enabled (server-side only —
# powers the live distance + fare estimate on the quote form). Without it the
# quote form returns an error. This is a RUNTIME variable; changing it does not
# require a rebuild.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── RECOMMENDED ──────────────────────────────────────────────────────────────

# Public URL of the deployed site. Used by auth/cookies.
AUTH_URL=https://tristaravel.com

# Random secret for signing sessions/cookies. Generate one with:
#   openssl rand -base64 32
# Only strictly required if you enable the @auth/core email/password user login;
# the driver portal has its own session system and works without it. Safe to set.
AUTH_SECRET=

# ── OPTIONAL ─────────────────────────────────────────────────────────────────

# Port the server listens on. Railway and most hosts inject this automatically;
# leave unset there. Defaults to 3000 if not provided.
# PORT=3000

# Comma-separated list of allowed CORS origins (only needed if a separate
# frontend/app calls this server cross-origin). Usually leave unset.
# CORS_ORIGINS=https://tristaravel.com

# Force the DB driver instead of auto-detecting from the URL (neon | postgres).
# Auto-detection works for *.neon.tech (neon) and everything else (postgres).
# DB_DRIVER=postgres
